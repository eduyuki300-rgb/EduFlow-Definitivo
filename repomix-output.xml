<file path="firestore.rules">
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    function isValidTask(data) {
      // Campos obrigatórios básicos
      return data.keys().hasAll(['title', 'subject', 'priority', 'status', 'userId', 'createdAt']) &&
             isValidString('title', 1, 300) &&
             isValidString('subject', 1, 100) &&
             // Flexibilidade para prioridades e status
             data.userId == request.auth.uid &&
             data.createdAt is timestamp &&
             // Validação de tipos para campos opcionais (apenas se presentes)
             (!('subtasks' in data) || data.subtasks is list) &&
             (!('notes' in data) || data.notes is string) &&
             (!('pomodoros' in data) || data.pomodoros is number) &&
             (!('liquidTime' in data) || data.liquidTime is number);
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      allow create: if isAuthenticated() && 
                    isValidTask(request.resource.data);
                    
      allow update: if isAuthenticated() && 
                    resource.data.userId == request.auth.uid &&
                    isValidTask(request.resource.data) &&
                    request.resource.data.userId == resource.data.userId &&
                    // Ensure createdAt is never changed
                    request.resource.data.createdAt == resource.data.createdAt;
                    
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
