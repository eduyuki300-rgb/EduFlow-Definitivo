};

const app = initializeApp(firebaseConfig);
export const db = initializeFirestore(app, {
  localCache: persistentLocalCache({ tabManager: persistentMultipleTabManager() })
}, import.meta.env.VITE_FIREBASE_DATABASE_ID || '(default)');
