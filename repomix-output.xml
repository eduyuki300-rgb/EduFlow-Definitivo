<file path="Sincronizar-GitHub.bat">
@echo off
setlocal enabledelayedexpansion

echo ########################################
echo #    EduFlow - Sincronizador GitHub    #
echo ########################################
echo.

:: 1. Verificar se há alterações
echo [1/4] Verificando alteracoes locais...
git status -s

:: 2. Solicitar mensagem de commit
echo.
